# Set these before starting `ollama serve` (they're server-side settings --
# our Python client can't set them per-request). Both are memory/GPU
# guardrails, not speed techniques: they cap how many models Ollama will
# ever hold resident at once and how many requests it serves in parallel,
# so a misconfigured or concurrent run can't silently stack up multiple
# loaded models and eat all available unified memory.
#
# See src/processors/abstractive.py's OLLAMA_RESIDENT_CEILING_GB for the
# code-level guardrail that fails loudly if a single model's resident size
# exceeds the configured ceiling.
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# Only needed inside Docker, to reach the host's Ollama from the container.
# See docker-compose.yml.
# OLLAMA_HOST=http://host.docker.internal:11434
